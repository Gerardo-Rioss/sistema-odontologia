# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/odontologia?schema=public"
DATABASE_URL_PROD="postgresql://user:password@host:5432/database?schema=public"

# NextAuth.js
NEXTAUTH_SECRET="genera-un-secreto-seguro-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Calendar Sync)
GOOGLE_CLIENT_ID="tu-google-client-id"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/calendar/auth/callback"

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID="tu-whatsapp-phone-number-id"
WHATSAPP_BUSINESS_ACCOUNT_ID="tu-whatsapp-business-account-id"
WHATSAPP_TOKEN="tu-whatsapp-token"
WHATSAPP_VERIFY_TOKEN="tu-whatsapp-verify-token"
WHATSAPP_APP_SECRET="tu-whatsapp-app-secret"

# WhatsApp Bot Configuration
DENTIST_USER_ID="id-del-usuario-dentista"
CRON_SECRET="secreto-para-endpoint-cron"
CRON_ENABLED="false"

# Sentry (Error Monitoring)
# Obtené estos valores en https://sentry.io > Settings > Projects
NEXT_PUBLIC_SENTRY_DSN="https://example@sentry.io/project-id"
SENTRY_DSN="https://example@sentry.io/project-id"
SENTRY_ORG="tu-sentry-org"
SENTRY_PROJECT="tu-sentry-project"
# Solo necesario en CI/CD para subir source maps
SENTRY_AUTH_TOKEN=""
